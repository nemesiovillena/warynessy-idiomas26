---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import { avisoLegalTranslations } from '../../lib/i18n/legal-page-translations';

const { lang } = Astro.params;
const locale = lang || 'es';

const t = avisoLegalTranslations[locale as keyof typeof avisoLegalTranslations] ?? avisoLegalTranslations.es;
---

<MainLayout title={t.pageTitle}>
  <Section class="py-32 bg-white min-h-screen">
    <Container class="max-w-4xl">
      <h1 class="text-4xl font-serif font-bold mb-8 text-gray-900">{t.h1}</h1>
      <div class="prose prose-lg max-w-none text-gray-700">

        <p>{t.intro}</p>

        <h2>{t.s1Title}</h2>
        <ul>
          <li><strong>{t.s1Company}</strong> Restaurante Warynessy</li>
          <li><strong>{t.s1Address}</strong> Villena, Alicante, España</li>
          <li><strong>{t.s1CIF}</strong> {t.s1CIFVal}</li>
          <li><strong>{t.s1Phone}</strong> {t.s1PhoneVal}</li>
          <li><strong>{t.s1Email}</strong> contacto@warynessy.com</li>
          <li><strong>{t.s1Domain}</strong> warynessy.com</li>
        </ul>

        <h2>{t.s2Title}</h2>
        <p>{t.s2}</p>

        <h2>{t.s3Title}</h2>
        <p>{t.s3}</p>
        <ul>
          <li>{t.s3li1}</li>
          <li>{t.s3li2}</li>
          <li>{t.s3li3}</li>
          <li>{t.s3li4}</li>
        </ul>

        <h2>{t.s4Title}</h2>
        <p>{t.s4p1}</p>
        <p>{t.s4p2}</p>

        <h2>{t.s5Title}</h2>
        <p>{t.s5}</p>

        <h2>{t.s6Title}</h2>
        <p>{t.s6}</p>

        <h2>{t.s7Title}</h2>
        <p>{t.s7}</p>

        <h2>{t.s8Title}</h2>
        <p>{t.s8}</p>

        <h2>{t.s9Title}</h2>
        <p>{t.s9}</p>

        <p class="text-sm text-gray-500 mt-12 italic">{t.lastUpdated}</p>
      </div>
    </Container>
  </Section>
</MainLayout>
