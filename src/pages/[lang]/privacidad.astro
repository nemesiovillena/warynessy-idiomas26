---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import { privacidadTranslations } from '../../lib/i18n/legal-page-translations';

const { lang } = Astro.params;
const locale = lang || 'es';

const t = privacidadTranslations[locale as keyof typeof privacidadTranslations] ?? privacidadTranslations.es;
---

<MainLayout title={t.pageTitle}>
  <Section class="py-32 bg-white min-h-screen">
    <Container class="max-w-4xl">
      <h1 class="text-4xl font-serif font-bold mb-8 text-gray-900">{t.h1}</h1>
      <div class="prose prose-lg max-w-none text-gray-700">

        <p>{t.intro}</p>

        <h2>{t.s1Title}</h2>
        <ul>
          <li><strong>{t.s1Identity}</strong> Restaurante Warynessy</li>
          <li><strong>{t.s1Address}</strong> Villena, Alicante, España</li>
          <li><strong>{t.s1Email}</strong> contacto@warynessy.com</li>
        </ul>

        <h2>{t.s2Title}</h2>
        <p>{t.s2}</p>
        <ul>
          <li>{t.s2li1}</li>
          <li>{t.s2li2}</li>
          <li>{t.s2li3}</li>
          <li>{t.s2li4}</li>
        </ul>

        <h2>{t.s3Title}</h2>
        <p>{t.s3}</p>
        <ul>
          <li>{t.s3li1}</li>
          <li>{t.s3li2}</li>
          <li>{t.s3li3}</li>
        </ul>

        <h2>{t.s4Title}</h2>
        <p>{t.s4}</p>
        <ul>
          <li>{t.s4li1}</li>
          <li>{t.s4li2}</li>
          <li>{t.s4li3}</li>
        </ul>

        <h2>{t.s5Title}</h2>
        <p>{t.s5}</p>

        <h2>{t.s6Title}</h2>
        <p>{t.s6}</p>
        <ul>
          <li><strong>{t.s6Access}</strong> {t.s6AccessDesc}</li>
          <li><strong>{t.s6Rectification}</strong> {t.s6RectificationDesc}</li>
          <li><strong>{t.s6Deletion}</strong> {t.s6DeletionDesc}</li>
          <li><strong>{t.s6Restriction}</strong> {t.s6RestrictionDesc}</li>
          <li><strong>{t.s6Portability}</strong> {t.s6PortabilityDesc}</li>
          <li><strong>{t.s6Opposition}</strong> {t.s6OppositionDesc}</li>
        </ul>
        <p>{t.s6Contact} <strong>contacto@warynessy.com</strong> {t.s6ContactSuffix}</p>
        <p>{t.s6AEPD} <a href="https://www.aepd.es" target="_blank" rel="noopener">www.aepd.es</a>.</p>

        <h2>{t.s7Title}</h2>
        <p>{t.s7}</p>

        <h2>{t.s8Title}</h2>
        <p>{t.s8}</p>

        <p class="text-sm text-gray-500 mt-12 italic">{t.lastUpdated}</p>
      </div>
    </Container>
  </Section>
</MainLayout>
