---
/**
 * LanguageSelector Component
 * Permite cambiar el idioma del sitio con un diseño elegante y moderno.
 */
import { getTranslations } from '../../lib/i18n';

const { currentLocale } = Astro;

const languages = [
  { code: 'es', label: 'Castellano', flag: '🇪🇸' },
  { code: 'ca', label: 'Valencià', flag: '🚩' },
  { code: 'en', label: 'English', flag: '🇬🇧' },
  { code: 'fr', label: 'Français', flag: '🇫🇷' },
  { code: 'de', label: 'Deutsch', flag: '🇩🇪' },
];

const currentLanguage = languages.find(l => l.code === (currentLocale || 'es')) || languages[0];
const selectLabel = getTranslations(currentLocale || 'es').langSelector.label;

// Obtener la ruta actual sin el prefijo del idioma
const pathname = Astro.url.pathname;
const segments = pathname.split('/').filter(Boolean);
// Si el primer segmento es un código de idioma, lo quitamos
const cleanPathname = languages.some(l => l.code === segments[0]) 
  ? '/' + segments.slice(1).join('/') 
  : pathname;

function getUrlForLocale(localeCode: string) {
  return `/${localeCode}${cleanPathname}`.replace(/\/+$/, '') || `/${localeCode}`;
}
---

<div class="relative js-language-selector">
  <button
    type="button"
    class="js-lang-toggle flex items-center gap-2 px-3 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-md text-white/80 hover:text-white hover:border-white/30 transition-all duration-300"
    aria-expanded="false"
    aria-haspopup="true"
  >
    <span class="text-lg leading-none">{currentLanguage.flag}</span>
    <span class="text-sm font-medium hidden md:inline uppercase">{currentLanguage.code}</span>
    <span class="js-lang-chevron material-symbols-outlined text-sm transition-transform duration-300">expand_more</span>
  </button>

  <!-- Dropdown Menu -->
  <div
    class="js-lang-dropdown absolute right-0 top-full mt-2 w-48 py-2 rounded-2xl border border-white/10 bg-black/80 backdrop-blur-xl shadow-2xl opacity-0 invisible translate-y-2 transition-all duration-300 z-50 overflow-hidden"
  >
    <div class="px-4 py-2 text-[10px] uppercase tracking-widest text-white/40 font-bold border-b border-white/5 mb-1">
      {selectLabel}
    </div>
    {languages.map((lang) => (
      <a
        href={getUrlForLocale(lang.code)}
        class={`flex items-center justify-between px-4 py-3 text-sm transition-colors hover:bg-white/10 ${
          lang.code === currentLanguage.code ? 'text-primary font-bold bg-white/5' : 'text-white/70'
        }`}
      >
        <div class="flex items-center gap-3">
          <span class="text-lg leading-none">{lang.flag}</span>
          <span>{lang.label}</span>
        </div>
        {lang.code === currentLanguage.code && (
          <span class="material-symbols-outlined text-sm">check</span>
        )}
      </a>
    ))}
  </div>
</div>

<script>
  function initLanguageSelector() {
    const selectors = document.querySelectorAll('.js-language-selector');

    selectors.forEach(selector => {
      const toggle = selector.querySelector('.js-lang-toggle') as HTMLButtonElement;
      const dropdown = selector.querySelector('.js-lang-dropdown') as HTMLDivElement;
      const chevron = selector.querySelector('.js-lang-chevron') as HTMLElement;

      if (!toggle || !dropdown) return;

      function openDropdown() {
        dropdown.classList.remove('opacity-0', 'invisible', 'translate-y-2');
        dropdown.classList.add('opacity-100', 'visible', 'translate-y-0');
        chevron?.classList.add('rotate-180');
        toggle.setAttribute('aria-expanded', 'true');
      }

      function closeDropdown() {
        dropdown.classList.add('opacity-0', 'invisible', 'translate-y-2');
        dropdown.classList.remove('opacity-100', 'visible', 'translate-y-0');
        chevron?.classList.remove('rotate-180');
        toggle.setAttribute('aria-expanded', 'false');
      }

      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        
        // Cerrar otros dropdowns primero para evitar solapamientos
        document.querySelectorAll('.js-language-selector').forEach(other => {
          if (other !== selector) {
            const otherToggle = other.querySelector('.js-lang-toggle');
            const otherDropdown = other.querySelector('.js-lang-dropdown');
            const otherChevron = other.querySelector('.js-lang-chevron');
            
            otherDropdown?.classList.add('opacity-0', 'invisible', 'translate-y-2');
            otherDropdown?.classList.remove('opacity-100', 'visible', 'translate-y-0');
            otherChevron?.classList.remove('rotate-180');
            otherToggle?.setAttribute('aria-expanded', 'false');
          }
        });

        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        isOpen ? closeDropdown() : openDropdown();
      });

      // Cerrar al hacer click fuera
      document.addEventListener('click', (e) => {
        if (!selector.contains(e.target as Node)) {
          closeDropdown();
        }
      });
    });
  }

  // Ejecutar en carga inicial y en cada navegación de Astro (View Transitions)
  document.addEventListener('astro:page-load', initLanguageSelector);
</script>
